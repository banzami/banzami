{
  "name": "banza/sdk",
  "description": "Official Banza PHP SDK — wallet-native payment network for Angola",
  "type": "library",
  "license": "MIT",
  "keywords": ["banza", "payments", "angola", "qr", "wallets", "fintech"],
  "homepage": "https://banza.network",
  "require": {
    "php": "^8.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "guzzlehttp/guzzle": "^7.0",
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Required if you do not bring your own PSR-18 client.",
    "laravel/framework": "Required for the BanzaServiceProvider."
  },
  "autoload": {
    "psr-4": {
      "Banza\\": "src/",
      "Banza\\Laravel\\": "laravel/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Banza\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Banza\\Laravel\\BanzaServiceProvider"
      ],
      "aliases": {
        "Banza": "Banza\\Laravel\\Facades\\Banza"
      }
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
