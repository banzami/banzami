{
  "name": "banzami/sdk",
  "description": "Official Banzami PHP SDK — wallet-native payment network for Angola",
  "type": "library",
  "license": "MIT",
  "keywords": ["banzami", "payments", "angola", "qr", "wallets", "fintech"],
  "homepage": "https://banzami.org",
  "require": {
    "php": "^8.1",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "guzzlehttp/guzzle": "^7.0",
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Required if you do not bring your own PSR-18 client.",
    "laravel/framework": "Required for the BanzamiServiceProvider."
  },
  "autoload": {
    "psr-4": {
      "Banzami\\": "src/",
      "Banzami\\Laravel\\": "laravel/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Banzami\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Banzami\\Laravel\\BanzamiServiceProvider"
      ],
      "aliases": {
        "Banzami": "Banzami\\Laravel\\Facades\\Banzami"
      }
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
