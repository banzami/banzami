# BanzamIA Configuration
# Copy to .env and adjust for your environment

# Operating mode: demo | live-api-no-model | live-ai
BANZAI_MODE=live-api-no-model

# Server port
BANZAI_PORT=4200

# Qdrant vector store
BANZAI_QDRANT_URL=http://localhost:6333
BANZAI_COLLECTION=banzamia_knowledge

# Embedding provider: mock | local | remote
# mock   — deterministic random vectors, no model required (tests/dev)
# local  — @huggingface/transformers + BGE model downloaded from HuggingFace Hub
# remote — OpenAI-compatible embedding endpoint (vLLM serving an embedding model)
BANZAI_EMBEDDING_PROVIDER=mock

# Embedding dimension (must match model; BGE-large=1024, all-MiniLM-L6-v2=384)
BANZAI_EMBEDDING_DIMS=1024

# Local embedding model (provider=local only)
BANZAI_EMBEDDING_MODEL=Xenova/bge-large-en-v1.5

# Remote embedding endpoint (provider=remote only)
BANZAI_EMBEDDING_URL=http://localhost:8000/v1/embeddings
BANZAI_EMBEDDING_REMOTE_MODEL=bge-large-en-v1.5

# vLLM inference endpoint (mode=live-ai only)
BANZAI_VLLM_URL=http://localhost:8000/v1

# Model IDs for vLLM (mode=live-ai only)
BANZAI_MODEL_QWEN=Qwen/Qwen2.5-7B-Instruct
BANZAI_MODEL_QWEN_CODER=Qwen/Qwen2.5-Coder-7B-Instruct
BANZAI_MODEL_DEEPSEEK=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B

# Path to Banzami repo root (for document indexing)
# Default is ../../ which resolves to repo root from apps/banzamia/
BANZAI_DOCS_ROOT=../../
