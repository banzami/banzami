{
  "_spec": "Banza Operator Conformance Suite v1.0",
  "_description": "Tests that any operator implementing the Banza protocol must pass.",
  "_target": "HTTP operator at configurable base URL",

  "suite_id": "operators",
  "suite_name": "Operator Conformance",
  "protocol_version": "1.0",

  "certification_levels": {
    "0": {
      "name": "Reference-compatible",
      "description": "Health endpoint, wallet creation, basic transfer, environment isolation",
      "required_suites": ["health", "wallets", "transfers-basic", "environment"]
    },
    "1": {
      "name": "Protocol-compatible",
      "description": "All Level 0 + QR, payment requests, events, ledger, settlement",
      "required_suites": ["qr", "payment-requests", "events", "ledger", "settlement"]
    },
    "2": {
      "name": "Trace-compatible",
      "description": "All Level 1 + trace_id on all operations, GET /traces, causation_id",
      "required_suites": ["traces"]
    },
    "3": {
      "name": "Federation-ready",
      "description": "All Level 2 + valid manifest, capability declaration",
      "required_suites": ["manifest", "capabilities"]
    },
    "4": {
      "name": "Settlement-compatible",
      "description": "All Level 3 + settlement fee model, no-money-creation invariant",
      "required_suites": ["settlement-invariants"]
    }
  },

  "sub_suites": [
    {
      "id": "health",
      "name": "Health",
      "certification_level": 0,
      "cases": [
        {
          "id": "HEALTH-001",
          "title": "GET /health returns 200 with status ok",
          "method": "GET",
          "path": "/health",
          "expect_status": 200,
          "expect_field_values": {
            "status": "ok",
            "environment": "sandbox"
          }
        },
        {
          "id": "HEALTH-002",
          "title": "Health response declares simulated=true and production_allowed=false",
          "method": "GET",
          "path": "/health",
          "expect_status": 200,
          "expect_field_values": {
            "simulated": true,
            "production_allowed": false
          }
        }
      ]
    },
    {
      "id": "environment",
      "name": "Environment isolation",
      "certification_level": 0,
      "cases": [
        {
          "id": "ENV-001",
          "title": "Operator refuses to declare production_allowed=true",
          "description": "The health endpoint and manifest must NEVER return production_allowed=true for a sandbox operator. This is a hard safety invariant.",
          "method": "GET",
          "path": "/health",
          "expect_status": 200,
          "expect_field_values": { "production_allowed": false }
        }
      ]
    },
    {
      "id": "wallets",
      "name": "Wallet management",
      "certification_level": 0,
      "vectors": ["WLT-001", "WLT-002", "WLT-004", "WLT-005"]
    },
    {
      "id": "transfers-basic",
      "name": "Transfer basics",
      "certification_level": 0,
      "vectors": ["TRF-001", "TRF-002", "TRF-003", "TRF-004", "TRF-005", "TRF-006"]
    },
    {
      "id": "qr",
      "name": "QR payment flow",
      "certification_level": 1,
      "vectors": ["QR-001", "QR-002", "QR-003", "QR-004", "QR-005", "QR-007"]
    },
    {
      "id": "payment-requests",
      "name": "Payment request lifecycle",
      "certification_level": 1,
      "vectors": ["PR-001", "PR-002", "PR-003", "PR-006"]
    },
    {
      "id": "events",
      "name": "Event emission",
      "certification_level": 1,
      "vectors": ["EVT-001", "EVT-002", "EVT-003", "EVT-005", "EVT-006", "EVT-007", "EVT-008"]
    },
    {
      "id": "ledger",
      "name": "Ledger invariants",
      "certification_level": 1,
      "vectors": ["LED-001", "LED-002", "LED-003", "LED-005"]
    },
    {
      "id": "settlement",
      "name": "Settlement simulation",
      "certification_level": 1,
      "vectors": ["STL-001", "STL-002", "STL-005"]
    },
    {
      "id": "traces",
      "name": "Financial traceability",
      "certification_level": 2,
      "vectors": ["TRF-008", "TRF-009", "QR-006", "PR-004", "PR-005", "STL-004", "LED-004", "EVT-004"]
    },
    {
      "id": "manifest",
      "name": "Operator manifest",
      "certification_level": 3,
      "vectors": ["MAN-001", "MAN-002", "MAN-003", "MAN-004"]
    },
    {
      "id": "capabilities",
      "name": "Capability declarations",
      "certification_level": 3,
      "cases": [
        {
          "id": "CAP-001",
          "title": "Manifest declares supports_wallets=true",
          "method": "GET",
          "path": "/.well-known/banzami/operator.json",
          "expect_status": 200,
          "expect_nested": { "capabilities.supports_wallets": true }
        },
        {
          "id": "CAP-002",
          "title": "Manifest declares supports_qr=true",
          "method": "GET",
          "path": "/.well-known/banzami/operator.json",
          "expect_status": 200,
          "expect_nested": { "capabilities.supports_qr": true }
        }
      ]
    },
    {
      "id": "settlement-invariants",
      "name": "Settlement invariants",
      "certification_level": 4,
      "vectors": ["STL-003", "STL-006"]
    }
  ],

  "invariants": {
    "zero_sum_ledger": "Every transfer must create DEBIT and CREDIT entries of exactly equal amount",
    "no_negative_balance": "No wallet may reach a negative balance",
    "idempotency": "Same idempotency key always returns the same result with no side effects",
    "trace_id_propagation": "All entities in a flow share the same trace_id",
    "causation_id_set": "Derived transfers carry causation_id pointing to the triggering entity",
    "ledger_immutability": "No ledger entry is modified after creation",
    "single_use_qr": "A paid QR code cannot be paid again",
    "single_use_pr": "A paid payment request cannot be paid again",
    "settlement_no_money_creation": "net_minor + fee_minor must equal gross_minor exactly",
    "settlement_idempotency": "A transfer appears in exactly one settlement batch"
  }
}
