{
  "_spec": "the reference operator Event Schema Conformance Suite v1.0",

  "suite_id": "events",
  "suite_name": "Event Schema Validation",
  "protocol_version": "1.0",

  "required_envelope_fields": [
    "id",
    "event_type",
    "aggregate_type",
    "aggregate_id",
    "trace_id",
    "correlation_id",
    "payload",
    "created_at"
  ],

  "optional_envelope_fields": [
    "causation_id"
  ],

  "field_rules": {
    "id": { "type": "string", "pattern": "^evt-", "description": "Event ID must start with evt-" },
    "event_type": { "type": "string", "enum_from": "well_known_event_types" },
    "aggregate_type": { "type": "string", "allowed": ["transfer", "payment_request", "qr", "wallet", "settlement"] },
    "aggregate_id": { "type": "string", "min_length": 1 },
    "trace_id": { "type": "string", "pattern": "^tr-" },
    "correlation_id": { "type": "string", "min_length": 1 },
    "causation_id": { "type": "string", "nullable": true },
    "payload": { "type": "object" },
    "created_at": { "type": "string", "format": "iso8601" }
  },

  "well_known_event_types": [
    "wallet.created",
    "payment.sent",
    "payment.received",
    "payment_request.created",
    "payment_request.paid",
    "qr.generated",
    "qr.paid",
    "settlement.created",
    "settlement.completed"
  ],

  "event_payload_schemas": {
    "wallet.created": {
      "required": ["wallet_id", "label", "currency"]
    },
    "payment.sent": {
      "required": ["transfer_id", "from_wallet_id", "amount_minor", "currency"]
    },
    "payment.received": {
      "required": ["transfer_id", "to_wallet_id", "amount_minor", "currency"]
    },
    "payment_request.created": {
      "required": ["pr_id", "to_wallet_id", "amount_minor", "currency"]
    },
    "payment_request.paid": {
      "required": ["pr_id", "transfer_id", "amount_minor"]
    },
    "qr.generated": {
      "required": ["qr_id", "merchant_wallet_id", "currency"]
    },
    "qr.paid": {
      "required": ["qr_id", "transfer_id", "amount_minor"]
    },
    "settlement.created": {
      "required": ["batch_id", "wallet_id", "gross_minor", "net_minor", "tx_count"]
    },
    "settlement.completed": {
      "required": ["batch_id"]
    }
  },

  "ordering_guarantees": {
    "description": "Events in GET /events/history are stored in emission order. The timeline in GET /traces/:id is sorted by timestamp ascending.",
    "payment_pair_order": "payment.sent must be emitted before payment.received within the same transfer"
  },

  "backward_compatibility": {
    "rule": "New optional fields may be added to any event payload at any time without a major version bump.",
    "rule2": "Existing required fields must never be removed.",
    "rule3": "The set of well_known_event_types may be extended but not reduced."
  },

  "sub_suites": [
    {
      "id": "envelope-fields",
      "name": "Envelope field presence",
      "vectors": ["EVT-004"]
    },
    {
      "id": "event-emission",
      "name": "Event emission per operation",
      "vectors": ["EVT-001", "EVT-002", "EVT-003", "EVT-005", "EVT-006", "EVT-007", "EVT-008"]
    },
    {
      "id": "trace-fields",
      "name": "Trace fields on events",
      "certification_level": 2,
      "vectors": ["EVT-004"]
    }
  ]
}
