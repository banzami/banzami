{
    "name": "banzami/banzami-laravel",
    "description": "Banzami payment gateway for Laravel — service provider, facade, and webhook middleware",
    "license": "UNLICENSED",
    "type": "library",
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^10|^11",
        "banzami/banzami-php": "^0.1"
    },
    "require-dev": {
        "orchestra/testbench": "^8|^9",
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "Banzami\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Banzami\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Banzami\\Laravel\\BanzamiServiceProvider"],
            "aliases":   {"Banzami": "Banzami\\Laravel\\Facades\\Banzami"}
        }
    }
}
